<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Desktop.Avalonia.Views.FsmVisualizationView">
  
  <Border Background="{DynamicResource Brush.Black}" 
          Padding="14" 
          Height="100">
    <StackPanel Spacing="10" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center">
      <TextBlock Text="Transaction State Flow" 
                 FontSize="15" FontWeight="Bold" 
                 Foreground="{DynamicResource Brush.Light}" 
                 HorizontalAlignment="Center"/>
      
      <Grid ColumnDefinitions="auto,auto,auto,auto,auto"
            RowDefinitions="Auto" 
            Margin="1">

        <Border Grid.Column="0" Grid.Row="0" 
                Name="NodeIdle" 
                Margin="4"
                Padding="10" 
                CornerRadius="8" 
                Background="{DynamicResource Brush.Brown}" 
                BorderThickness="2" BorderBrush="{DynamicResource Brush.Light}" 
                Opacity="0.5">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Idle" FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- AwaitingPayment -->
        <Border Grid.Column="1" Grid.Row="0"
                Name="NodeAwaitingPayment"
                Margin="4"
                Padding="10"
                CornerRadius="8"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.Light}"
                Opacity="0.5">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Awaiting Pay"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Cancelled -->
        <Border Grid.Column="2" Grid.Row="0"
                Name="NodeCancelled"
                Margin="4"
                Padding="10"
                CornerRadius="8"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.Light}"
                Opacity="0.5">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Cancelled"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- ProcessingPayment -->
        <Border Grid.Column="3" Grid.Row="0"
                Name="NodeProcessingPayment"
                Margin="4"
                Padding="10"
                CornerRadius="8"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.Light}"
                Opacity="0.5">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Processing"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Completed -->
        <Border Grid.Column="4" Grid.Row="0"
                Name="NodeCompleted"
                Margin="4"
                Padding="10"
                CornerRadius="8"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.Light}"
                Opacity="0.5">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Completed"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
