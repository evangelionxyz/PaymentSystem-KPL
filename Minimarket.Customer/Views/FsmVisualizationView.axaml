<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Desktop.Avalonia.Views.FsmVisualizationView">
  <Border Background="{DynamicResource Brush.DarkBrown}"
          CornerRadius="12"
          Padding="16"
          MaxHeight="100"
          HorizontalAlignment="Stretch">
    <Grid RowDefinitions="Auto,Auto"
          RowSpacing="8"
          HorizontalAlignment="Stretch">
      <TextBlock Text="Transaction State Flow"
                 FontSize="14"
                 FontWeight="Bold"
                 Foreground="{DynamicResource Brush.Light}"
                 HorizontalAlignment="Center"/>

      <Grid Grid.Row="1"
            ColumnDefinitions="*,*,*,*,*"
            ColumnSpacing="8"
            HorizontalAlignment="Stretch">

        <Border Grid.Column="0"
                Name="NodeIdle"
                Padding="12"
                MinHeight="12"
                CornerRadius="10"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.LightBrown}"
                Opacity="0.55">
          <TextBlock Text="Idle"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.Light}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Column="1"
                Name="NodeAwaitingPayment"
                Padding="12"
                MinHeight="12"
                CornerRadius="10"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.LightBrown}"
                Opacity="0.55">
          <TextBlock Text="Awaiting Pay"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.Light}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Column="2"
                Name="NodeCancelled"
                Padding="12"
                MinHeight="12"
                CornerRadius="10"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.LightBrown}"
                Opacity="0.55">
          <TextBlock Text="Cancelled"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.Light}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Column="3"
                Name="NodeProcessingPayment"
                Padding="12"
                MinHeight="12"
                CornerRadius="10"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.LightBrown}"
                Opacity="0.55">
          <TextBlock Text="Processing"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.Light}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Column="4"
                Name="NodeCompleted"
                Padding="12"
                MinHeight="12"
                CornerRadius="10"
                Background="{DynamicResource Brush.Brown}"
                BorderThickness="2"
                BorderBrush="{DynamicResource Brush.LightBrown}"
                Opacity="0.55">
          <TextBlock Text="Completed"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.Light}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
      </Grid>
    </Grid>
  </Border>
</UserControl>
