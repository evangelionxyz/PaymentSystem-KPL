<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Desktop.Avalonia.ViewModels"
             x:Class="Desktop.Avalonia.Views.ReceiptView"
             x:DataType="vm:ReceiptViewModel">

  <ScrollViewer Margin="20">
    <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Center">

      <!-- Header -->
      <TextBlock Text="🧾 Receipt" FontSize="26" FontWeight="Bold"
                 Foreground="#E0E0E0" HorizontalAlignment="Center"/>

      <!-- Receipt Card -->
      <Border Background="#1A1A2E" CornerRadius="12" Padding="24"
              IsVisible="{Binding HasReceipt}">
        <StackPanel Spacing="12">

          <!-- Store / Date -->
          <TextBlock Text="Minimarket POS"
                     FontSize="18" FontWeight="SemiBold"
                     Foreground="#64B5F6" HorizontalAlignment="Center"/>
          <TextBlock Text="{Binding Receipt.Date, StringFormat='{}{0:dd MMM yyyy  HH:mm}'}"
                     FontSize="12" Foreground="#9E9E9E" HorizontalAlignment="Center"/>

          <Separator Background="#2A2A4A" Margin="0,8"/>

          <!-- Items -->
          <TextBlock Text="{Binding ItemsDisplay}"
                     FontFamily="Consolas, Monospace"
                     FontSize="13" Foreground="#E0E0E0"/>

          <Separator Background="#2A2A4A" Margin="0,8"/>

          <!-- Totals -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Subtotal"       Foreground="#9E9E9E"/>
            <TextBlock Grid.Column="1" Text="{Binding Receipt.Subtotal,       StringFormat='Rp {0:N0}'}" Foreground="#E0E0E0"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Discount"       Foreground="#EF9A9A"/>
            <TextBlock Grid.Column="1" Text="{Binding Receipt.DiscountAmount, StringFormat='- Rp {0:N0}'}" Foreground="#EF9A9A"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Tax"            Foreground="#9E9E9E"/>
            <TextBlock Grid.Column="1" Text="{Binding Receipt.TaxAmount,      StringFormat='+ Rp {0:N0}'}" Foreground="#9E9E9E"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Payment Fee"    Foreground="#FFB74D"/>
            <TextBlock Grid.Column="1" Text="{Binding Receipt.FeeAmount,      StringFormat='+ Rp {0:N0}'}" Foreground="#FFB74D"/>
          </Grid>

          <Separator Background="#2A2A4A"/>

          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="TOTAL" FontWeight="Bold" FontSize="18" Foreground="#E0E0E0"/>
            <TextBlock Grid.Column="1" Text="{Binding Receipt.Total, StringFormat='Rp {0:N0}'}"
                       FontWeight="Bold" FontSize="18" Foreground="#81C784"/>
          </Grid>

          <Separator Background="#2A2A4A" Margin="0,8"/>

          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Payment Method" Foreground="#9E9E9E"/>
            <TextBlock Grid.Column="1" Text="{Binding Receipt.PaymentMethod}" Foreground="#E0E0E0"/>
          </Grid>

          <TextBlock Text="Thank you for shopping! 🙏"
                     FontSize="14" Foreground="#9E9E9E"
                     HorizontalAlignment="Center" Margin="0,16,0,0"/>
        </StackPanel>
      </Border>

      <!-- New Transaction Button -->
      <Button Content="🔄 New Transaction"
              Name="NewTransactionButton"
              Background="#1565C0" Foreground="White"
              FontSize="15" FontWeight="SemiBold"
              Padding="24,12" CornerRadius="8"
              HorizontalAlignment="Center"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>
