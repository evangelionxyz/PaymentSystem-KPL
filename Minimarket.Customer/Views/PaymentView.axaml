<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Desktop.Avalonia.ViewModels"
             x:Class="Desktop.Avalonia.Views.PaymentView"
             x:DataType="vm:PaymentViewModel">

  <UserControl.Styles>
    <Style Selector="ListBox#MethodList > ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="ListBox#MethodList > ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox#MethodList > ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox#MethodList > ListBoxItem:selected:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox#MethodList ListBoxItem Border.payment-method-card">
      <Setter Property="Background" Value="{DynamicResource Brush.Light}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.DarkBrown}"/>
    </Style>

    <Style Selector="ListBox#MethodList ListBoxItem:pointerover Border.payment-method-card">
      <Setter Property="Background" Value="{DynamicResource Brush.DarkBrown}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="ListBox#MethodList ListBoxItem:selected Border.payment-method-card">
      <Setter Property="Background" Value="{DynamicResource Brush.Brown}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="ListBox#MethodList ListBoxItem TextBlock.payment-method-text">
      <Setter Property="Foreground" Value="{DynamicResource Brush.DarkBrown}"/>
    </Style>
    <Style Selector="ListBox#MethodList ListBoxItem:pointerover TextBlock.payment-method-text">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Light}"/>
    </Style>
    <Style Selector="ListBox#MethodList ListBoxItem:selected TextBlock.payment-method-text">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Light}"/>
    </Style>

  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="20">

    <Grid Grid.Row="0"
          ColumnDefinitions="*,Auto"
          Margin="0,0,0,20">
      <TextBlock Text="Select Payment Method"
                 FontSize="22"
                 FontWeight="Bold"
                 Foreground="{DynamicResource Brush.DarkBrown}"
                 VerticalAlignment="Center"/>
      <Border Grid.Column="1"
              Background="{DynamicResource Brush.Accent}"
              CornerRadius="999"
              Padding="12,6"
              VerticalAlignment="Center">
        <TextBlock Text="{Binding CurrentFsmStateDisplay, StringFormat='State: {0}'}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.DarkBrown}"/>
      </Border>
    </Grid>

    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="10">

        <!-- Payment Method List -->
        <ListBox Name="MethodList"
                 ItemsSource="{Binding PaymentMethods}"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="payment-method-card"
                      CornerRadius="8"
                      Padding="16,12"
                      Margin="0,4">
                <TextBlock Classes="payment-method-text"
                           Text="{Binding}"
                           FontSize="14"
                           FontWeight="Medium"/>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Fee Preview -->
        <Border Background="{DynamicResource Brush.Light}"
                BorderBrush="{DynamicResource Brush.DarkBrown}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Payment Fee"
                         Foreground="{DynamicResource Brush.Brown}"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding FeeAmount, StringFormat='+ Rp {0:N0}'}"
                         Foreground="{DynamicResource Brush.Brown}"/>
            </Grid>
            <Rectangle Height="1"
                       Fill="{DynamicResource Brush.Brown}"
                       Opacity="0.3"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Final Total"
                         FontWeight="Bold"
                         FontSize="16"
                         Foreground="{DynamicResource Brush.DarkBrown}"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding FinalTotal, StringFormat='Rp {0:N0}'}"
                         FontWeight="Bold"
                         FontSize="16"
                         Foreground="{DynamicResource Brush.DarkBrown}"/>
            </Grid>
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Brush.Danger}"
                   FontSize="13"
                   Margin="0,8,0,0"/>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2"
                Spacing="10"
                Margin="16,0,0,0"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right">
      <Button Classes="secondary-action"
              Width="128"
              Height="38"
              Content="← Cart"
              Name="BackButton"
              CornerRadius="8"
              FontWeight="SemiBold"
              HorizontalAlignment="Center"
              VerticalContentAlignment="Center"
              HorizontalContentAlignment="Center"/>
      <Button Classes="accent-action"
              Width="128"
              Height="48"
              HorizontalAlignment="Center"
              VerticalContentAlignment="Center"
              HorizontalContentAlignment="Center"
              CornerRadius="8"
              Content="Pay Now →"
              Name="PayButton"
              FontWeight="SemiBold"
              FontSize="15"/>
    </StackPanel>

  </Grid>
</UserControl>
