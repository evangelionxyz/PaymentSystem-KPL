<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Desktop.Avalonia.ViewModels;assembly=Minimarket.Customer"
        xmlns:views="clr-namespace:Desktop.Avalonia.Views;assembly=Minimarket.Customer"
        x:Class="Minimarket.Cashier.MainWindow"
        x:DataType="vm:CashierViewModel"
        Title="Minimarket Cashier &amp; Admin Panel"
        Width="1024" Height="760"
        Background="#0D0D1A">

  <Grid RowDefinitions="Auto,*">
    
    <!-- Title Bar -->
    <Border Grid.Row="0" Background="#12122A" Padding="20,14">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0" Text="👤 Minimarket Cashier"
                   FontSize="18" FontWeight="Bold" Foreground="#81C784"
                   VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" Text="Cashier &amp; POS Administration"
                   Foreground="#555577" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Main Container -->
    <Grid Grid.Row="1">
      <!-- Auth Screen -->
      <views:AuthView DataContext="{Binding AuthVm}" Name="AuthPage" IsVisible="True"/>

      <!-- Dashboard Layout -->
      <Grid Name="DashboardGrid" IsVisible="False" ColumnDefinitions="260,*">
        
        <!-- Left Sidebar / Queue selector -->
        <Border Grid.Column="0" Background="#12122A" BorderBrush="#202040" BorderThickness="0,0,1,0" Padding="15">
          <Grid RowDefinitions="Auto,*,Auto">
            <TextBlock Grid.Row="0" Text="📥 Customer Queue" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            
            <ListBox Grid.Row="1" ItemsSource="{Binding PendingCarts}" SelectedItem="{Binding SelectedCart}"
                     Background="Transparent" BorderThickness="0" Name="QueueListBox">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Background="#1C1C3A" CornerRadius="6" Padding="10" Margin="0,4">
                    <StackPanel>
                      <TextBlock Text="{Binding ID, StringFormat='Cart: {0}'}" FontSize="12" FontWeight="Bold" Foreground="#90CAF9"/>
                      <TextBlock Text="{Binding Total, StringFormat='Rp {0:N0}'}" FontSize="13" Foreground="#81C784"/>
                      <TextBlock Text="{Binding TotalItems, StringFormat='{}{0} items'}" FontSize="11" Foreground="#B0BEC5"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2" Content="🔄 Refresh Queue" Name="RefreshQueueButton"
                    Background="#1E88E5" Foreground="White" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,10,0,0"/>
          </Grid>
        </Border>

        <!-- Right Main Workspace tabs -->
        <TabControl Grid.Column="1" Margin="10">
          
          <!-- Tab 1: FSM State Machine control -->
          <TabItem Header="🔄 Transaction FSM Control" Foreground="White" FontSize="14" FontWeight="SemiBold">
            <Grid RowDefinitions="*,Auto">
              
              <!-- State view -->
              <StackPanel Grid.Row="0" Spacing="20" Margin="10">
                <Border Background="#12122A" CornerRadius="8" Padding="15">
                  <StackPanel>
                    <TextBlock Text="Active Cart Details" FontSize="16" FontWeight="Bold" Foreground="#90CAF9" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding SelectedCart.ID, StringFormat='Cart ID: {0}'}" Foreground="White" Margin="0,2"/>
                    <TextBlock Text="{Binding SelectedCart.Total, StringFormat='Amount: Rp {0:N0}'}" Foreground="#81C784" FontSize="15" FontWeight="SemiBold" Margin="0,2"/>
                    <TextBlock Text="{Binding CurrentState, StringFormat='FSM State: {0}'}" Foreground="#FFB74D" FontWeight="Bold" Margin="0,2"/>
                  </StackPanel>
                </Border>

                <!-- Visualization canvas -->
                <views:FsmVisualizationView CurrentState="{Binding CurrentState}" Height="150"/>
              </StackPanel>

              <!-- Control actions -->
              <Border Grid.Row="1" Background="#12122A" Padding="15" CornerRadius="8" Margin="10">
                <StackPanel Spacing="10">
                  <TextBlock Text="Action Triggers (FSM Inputs)" FontSize="13" FontWeight="Bold" Foreground="#B0BEC5"/>
                  <Grid ColumnDefinitions="*,*,*,*">
                    <Button Grid.Column="0" Content="Pay Cash" Name="BtnPayCash" Margin="5" Padding="10" Background="#2E7D32" Foreground="White" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="Pay QRIS" Name="BtnPayQr" Margin="5" Padding="10" Background="#00838F" Foreground="White" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="Confirm Success" Name="BtnSuccess" Margin="5" Padding="10" Background="#1565C0" Foreground="White" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button Grid.Column="3" Content="Fail Payment" Name="BtnFail" Margin="5" Padding="10" Background="#C62828" Foreground="White" CornerRadius="6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                  </Grid>
                </StackPanel>
              </Border>

            </Grid>
          </TabItem>

          <!-- Tab 2: Admin Product Management -->
          <TabItem Header="🛠 Product CRUD" Foreground="White" FontSize="14" FontWeight="SemiBold">
            <Grid ColumnDefinitions="280,*">
              
              <!-- Form -->
              <Border Grid.Column="0" Background="#12122A" CornerRadius="8" Padding="15" Margin="5">
                <StackPanel Spacing="12">
                  <TextBlock Text="Manage Product" FontSize="16" FontWeight="Bold" Foreground="#90CAF9"/>
                  
                  <TextBox Name="TxtProdId" IsVisible="False"/>

                  <StackPanel Spacing="5">
                    <TextBlock Text="Name" Foreground="#B0BEC5" FontSize="11"/>
                    <TextBox Name="TxtProdName" Watermark="Product Name" Background="#1A1A35" Foreground="White"/>
                  </StackPanel>

                  <StackPanel Spacing="5">
                    <TextBlock Text="Category" Foreground="#B0BEC5" FontSize="11"/>
                    <ComboBox Name="ComboProdCategory" HorizontalAlignment="Stretch" Background="#1A1A35" Foreground="White">
                      <ComboBoxItem Content="Snack"/>
                      <ComboBoxItem Content="Beverage"/>
                      <ComboBoxItem Content="Fresh"/>
                      <ComboBoxItem Content="Household"/>
                    </ComboBox>
                  </StackPanel>

                  <StackPanel Spacing="5">
                    <TextBlock Text="Price" Foreground="#B0BEC5" FontSize="11"/>
                    <TextBox Name="TxtProdPrice" Watermark="Price (Rp)" Background="#1A1A35" Foreground="White"/>
                  </StackPanel>

                  <StackPanel Spacing="5">
                    <TextBlock Text="Stock" Foreground="#B0BEC5" FontSize="11"/>
                    <TextBox Name="TxtProdStock" Watermark="Stock quantity" Background="#1A1A35" Foreground="White"/>
                  </StackPanel>

                  <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
                    <Button Grid.Column="0" Content="Save" Name="BtnSaveProduct" Margin="3" Background="#2E7D32" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="Clear" Name="BtnClearProduct" Margin="3" Background="#37474F" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- List Grid -->
              <Border Grid.Column="1" Background="#12122A" CornerRadius="8" Padding="10" Margin="5">
                <ListBox ItemsSource="{Binding Products}" Name="ProductsListBox" Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="*,Auto,Auto" Margin="5">
                        <StackPanel Grid.Column="0">
                          <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White"/>
                          <TextBlock Text="{Binding CategoryId, StringFormat='Category: {0}'}" FontSize="11" Foreground="#B0BEC5"/>
                          <TextBlock Text="{Binding Stock, StringFormat='Stock: {0}'}" FontSize="11" Foreground="#B0BEC5"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat='Rp {0:N0}'}" VerticalAlignment="Center" Margin="10,0" Foreground="#81C784"/>
                        <Button Grid.Column="2" Content="🗑 Delete" Name="BtnDeleteProduct" Tag="{Binding}" Background="#C62828" Foreground="White" CornerRadius="4"/>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>

            </Grid>
          </TabItem>

          <!-- Tab 3: Audit Log & Replay -->
          <TabItem Header="📜 Audit Logs &amp; Replay" Foreground="White" FontSize="14" FontWeight="SemiBold">
            <Grid RowDefinitions="Auto,*,Auto" Margin="10">
              
              <!-- Search log -->
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                <TextBox Grid.Column="0" Text="{Binding AuditTransactionId, Mode=TwoWay}" Watermark="Enter Transaction (Cart) ID to retrieve logs" Background="#12122A" Foreground="White"/>
                <Button Grid.Column="1" Content="🔍 Load Log" Name="BtnLoadAuditLogs" Margin="10,0,0,0" Background="#1E88E5" Foreground="White"/>
              </Grid>

              <!-- Log display -->
              <Border Grid.Row="1" Background="#12122A" CornerRadius="8" Padding="10">
                <ListBox ItemsSource="{Binding AuditLogs}" Name="AuditLogsListBox" Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="#2C2C4E" BorderThickness="0,0,0,1" Padding="8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                          <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" Foreground="#90CAF9" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="15,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Trigger, StringFormat='Trigger: {0}'}" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding FromState, StringFormat='Transition: {0} '}" FontSize="11" Foreground="#B0BEC5"/>
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding ToState, StringFormat='➜ {0}'}" Foreground="#FFB74D" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>

              <!-- Replay controls -->
              <Border Grid.Row="2" Background="#1C1C3A" Padding="10" CornerRadius="8" Margin="0,10,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Button Grid.Column="0" Content="⏪ Step Backward" Name="BtnReplayPrev" Background="#37474F" Foreground="White"/>
                  <TextBlock Grid.Column="1" Text="Replay State Timeline" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  <Button Grid.Column="2" Content="Step Forward ⏩" Name="BtnReplayNext" Background="#1E88E5" Foreground="White"/>
                </Grid>
              </Border>

            </Grid>
          </TabItem>

        </TabControl>

      </Grid>
    </Grid>

  </Grid>
</Window>
