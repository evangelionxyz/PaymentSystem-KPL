<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Desktop.Avalonia.ViewModels"
             x:Class="Desktop.Avalonia.Views.PaymentView"
             x:DataType="vm:PaymentViewModel">

  <Grid RowDefinitions="Auto,*,Auto" Margin="20">

    <TextBlock Grid.Row="0" Text="💳 Select Payment Method"
               FontSize="22" FontWeight="Bold" Foreground="#E0E0E0" Margin="0,0,0,20"/>

    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="10">

        <!-- Payment Method Buttons (using ListBox for simple selection) -->
        <ListBox Name="MethodList"
                 ItemsSource="{Binding PaymentMethods}"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Background="#1A1A2E" CornerRadius="8" Padding="16,12" Margin="0,4">
                <TextBlock Text="{Binding}" FontSize="14" Foreground="#E0E0E0"/>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Fee Preview -->
        <Border Background="#1A1A2E" CornerRadius="8" Padding="16" Margin="0,16,0,0">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Payment Fee" Foreground="#FFB74D"/>
              <TextBlock Grid.Column="1" Text="{Binding FeeAmount, StringFormat='+ Rp {0:N0}'}"
                         Foreground="#FFB74D"/>
            </Grid>
            <Rectangle Height="1" Fill="#2A2A4A"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Final Total" FontWeight="Bold" FontSize="16" Foreground="#E0E0E0"/>
              <TextBlock Grid.Column="1" Text="{Binding FinalTotal, StringFormat='Rp {0:N0}'}"
                         FontWeight="Bold" FontSize="16" Foreground="#81C784"/>
            </Grid>
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#EF5350" FontSize="13"
                   Margin="0,8,0,0"/>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,16,0,0">
      <Button Grid.Column="0" Content="← Back to Cart" Name="BackButton"
              Background="#37474F" Foreground="White"
              Padding="16,10" CornerRadius="8" HorizontalAlignment="Left"/>
      <Button Grid.Column="1" Content="Pay Now →" Name="PayButton"
              Background="#2E7D32" Foreground="White"
              FontWeight="SemiBold" FontSize="15"
              Padding="24,12" CornerRadius="8"/>
    </Grid>

  </Grid>
</UserControl>
