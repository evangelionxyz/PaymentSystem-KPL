<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Desktop.Avalonia.ViewModels"
        xmlns:views="clr-namespace:Desktop.Avalonia.Views"
        x:Class="Desktop.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Minimarket POS"
        Width="1024" Height="720"
        Background="#0D0D1A">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Title Bar -->
    <Border Grid.Row="0" Background="#12122A" Padding="20,14">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0" Text="🛒 Minimarket POS"
                   FontSize="18" FontWeight="Bold" Foreground="#64B5F6"
                   VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1" Text="Minimarket Payment System"
                   Foreground="#555577" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="2" Name="ConnectivityText"
                   Text="{Binding ConnectivityBanner}"
                   Foreground="#FFB74D" FontSize="12" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Connectivity warning bar -->
    <Border Grid.Row="1" Background="#4A1A00" Padding="12,6"
            Name="OfflineBanner">
      <TextBlock Text="{Binding ConnectivityBanner}" Foreground="#FFB74D" FontSize="13"/>
    </Border>

    <!-- Page Content — visibility toggled from code-behind -->
    <Grid Grid.Row="2">
      <views:ProductScanView DataContext="{Binding ProductScanVm}"
                             Name="ProductScanPage"/>
      <views:CartView        DataContext="{Binding CartVm}"
                             Name="CartPage"
                             IsVisible="False"/>
      <views:PaymentView     DataContext="{Binding PaymentVm}"
                             Name="PaymentPage"
                             IsVisible="False"/>
      <views:ReceiptView     DataContext="{Binding ReceiptVm}"
                             Name="ReceiptPage"
                             IsVisible="False"/>
    </Grid>

  </Grid>
</Window>
